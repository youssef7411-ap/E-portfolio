# PRODUCTION ENVIRONMENT VARIABLES (Add these to Render Dashboard)
# -----------------------------------------------------------

# MONGODB CONNECTION
# Get this from your MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/e-portfolio?retryWrites=true&w=majority

# SECURITY
# Render will generate a random one if you leave it blank in render.yaml, 
# but it's better to set a permanent one.
JWT_SECRET=your_super_secret_random_string_here

# CLOUDINARY (Optional - for image/video storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS / FRONTEND URL
# Set this to your frontend URL (e.g., https://your-portfolio.vercel.app)
CLIENT_URL=*

# SERVER CONFIG
NODE_ENV=production
PORT=5002
ALLOW_MEMORY_FALLBACK=false
MAX_FILE_SIZE_MB=250
